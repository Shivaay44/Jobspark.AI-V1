rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validation helpers
    function isValidResume(data) {
      return data.title is string 
        && data.title.size() <= 200
        && data.ownerId == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidChat(data) {
      return data.userId == request.auth.uid
        && data.messages is list
        && data.messages.size() <= 500
        && data.updatedAt == request.time;
    }

    function isValidProfile(data) {
      return data.userId == request.auth.uid
        && data.email is string
        && data.email.size() <= 128;
    }

    // Match blocks
    match /resumes/{resumeId} {
      allow read, write: if request.auth != null && request.auth.uid == resumeId;
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() 
        && isValidId(chatId)
        && isValidChat(request.resource.data);
      allow update: if isSignedIn() 
        && isValidId(chatId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.updatedAt == request.time
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'updatedAt'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId 
        && isValidProfile(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'phone', 'location', 'linkedin', 'portfolio', 'isPro'])
        );
    }
  }
}
